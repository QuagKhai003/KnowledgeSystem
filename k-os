#!/usr/bin/env python3
"""Knowledge OS CLI — local knowledge compilation engine."""

import argparse
import json
import sys
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))

from src.ingestion.scanner import Scanner
from src.ingestion.state_db import StateDB
from src.ingestion.parsers import parse_file


def load_global_config() -> dict:
    """Load global config from ~/.k-os/config.yaml if it exists."""
    import yaml
    global_path = Path.home() / ".k-os" / "config.yaml"
    if global_path.exists():
        return yaml.safe_load(global_path.read_text()) or {}
    return {}


def load_config(workspace: str | None = None) -> dict:
    import yaml
    project_root = Path(__file__).resolve().parent
    config_path = project_root / "config" / "settings.yaml"
    config = yaml.safe_load(config_path.read_text())
    if workspace:
        config["workspace"]["root"] = str(Path(workspace).resolve())
    elif config["workspace"]["root"] == "auto":
        global_cfg = load_global_config()
        default_vault = global_cfg.get("default_vault", "")
        if default_vault:
            config["workspace"]["root"] = default_vault
        else:
            config["workspace"]["root"] = str(project_root)
    return config


def cmd_scan(args):
    """Run incremental scan and parse changed files."""
    config = load_config(args.workspace)
    root = Path(config["workspace"]["root"])
    db_path = root / config["workspace"]["state_db"]
    ignore_file = root / config["workspace"]["ignore_file"]

    state_db = StateDB(db_path)
    scanner = Scanner(root, state_db, ignore_file)

    start = time.time()
    changed_files = []

    for file_info in scanner.walk():
        result = parse_file(file_info["path"], file_info["file_type"])
        changed_files.append({
            "file": file_info["path"],
            "type": file_info["file_type"],
            "status": file_info["status"],
            "parsed": result is not None,
        })

        if args.verbose and result:
            print(f"  [{file_info['status']}] {file_info['path']}")

    elapsed = time.time() - start
    state_db.close()

    print(f"\nScan complete: {len(changed_files)} files processed in {elapsed:.2f}s")
    if args.json:
        print(json.dumps(changed_files, indent=2))


def cmd_parse(args):
    """Parse a single file and output its structure."""
    path = Path(args.file).resolve()
    if not path.exists():
        print(f"Error: {path} not found", file=sys.stderr)
        sys.exit(1)

    from src.ingestion.scanner import EXTENSION_MAP
    file_type = EXTENSION_MAP.get(path.suffix.lower())
    if not file_type:
        print(f"Error: unsupported extension {path.suffix}", file=sys.stderr)
        sys.exit(1)

    result = parse_file(str(path), file_type)
    print(json.dumps(result, indent=2, default=str))


def cmd_compile(args):
    """Scan, parse, and compile into Knowledge Objects."""
    from src.pipeline import KnowledgePipeline

    config = load_config(args.workspace)
    pipeline = KnowledgePipeline(config)

    print("Scanning...")
    scan_results = pipeline.scan_and_parse(verbose=args.verbose)
    print(f"  {len(scan_results)} files found")

    print("Compiling...")
    objects = pipeline.compile(scan_results, verbose=args.verbose)
    print(f"  {len(objects)} knowledge objects compiled")

    if args.json:
        output = [obj.to_dict() for obj in objects]
        print(json.dumps(output, indent=2, default=str))
    else:
        for obj in objects:
            print(f"  [{obj.ontology_class}] {obj.name} ({obj.id})")


def cmd_index(args):
    """Compile and index all objects into databases."""
    from src.pipeline import KnowledgePipeline

    config = load_config(args.workspace)
    pipeline = KnowledgePipeline(config)

    print("Scanning and parsing...")
    scan_results = pipeline.scan_and_parse(verbose=args.verbose)

    print("Compiling...")
    objects = pipeline.compile(scan_results, verbose=args.verbose)
    print(f"  {len(objects)} knowledge objects ready")

    print("Indexing into databases...")
    stats = pipeline.index(objects, verbose=args.verbose)
    print(f"  Indexed: {stats['indexed']}")
    print(f"  Failed:  {stats['failed']}")
    if stats["errors"]:
        for err in stats["errors"][:5]:
            print(f"    {err}")


def cmd_rebuild(args):
    """Full rebuild: wipe state and re-index everything."""
    from src.pipeline import KnowledgePipeline

    config = load_config(args.workspace)
    root = Path(config["workspace"]["root"])
    state_db_path = root / config["workspace"]["state_db"]

    if state_db_path.exists():
        state_db_path.unlink()
        print("State DB wiped.")

    pipeline = KnowledgePipeline(config)
    result = pipeline.full_rebuild(verbose=args.verbose)

    print(f"\n=== Rebuild Complete ===")
    print(f"  Files scanned:    {result['files_scanned']}")
    print(f"  Objects compiled: {result['objects_compiled']}")
    print(f"  Objects indexed:  {result['objects_indexed']}")
    print(f"  Index failures:   {result['index_failures']}")
    print(f"  Time:             {result['elapsed_seconds']}s")


def cmd_status(args):
    """Show state database summary."""
    config = load_config(args.workspace)
    root = Path(config["workspace"]["root"])
    db_path = root / config["workspace"]["state_db"]

    if not db_path.exists():
        print("No state database found. Run 'k-os scan' first.")
        return

    import sqlite3
    conn = sqlite3.connect(str(db_path))
    row = conn.execute("SELECT COUNT(*) as total, "
                       "SUM(CASE WHEN status='ACTIVE' THEN 1 ELSE 0 END) as active, "
                       "SUM(CASE WHEN status='DELETED' THEN 1 ELSE 0 END) as deleted "
                       "FROM file_state").fetchone()
    conn.close()

    print(f"Total tracked files: {row[0]}")
    print(f"  Active: {row[1]}")
    print(f"  Deleted: {row[2]}")


def cmd_query(args):
    """Plan and execute a knowledge query with live retrieval."""
    from src.planner import QueryPlanner
    from src.adapters import get_adapter

    planner = QueryPlanner()
    metadata = planner.plan_with_metadata(args.query, target_model=args.model)

    from src.adapters.base_adapter import detect_cli
    resolved = detect_cli() if args.model in ("auto", "default") else args.model

    print(f"Query:  {metadata['query']}")
    print(f"Intent: {metadata['intent']} (confidence: {metadata['confidence']:.0%})")
    print(f"Adapter: {resolved}" + (" (auto-detected)" if args.model in ("auto", "default") else ""))
    plan = metadata["plan"]
    print(f"Plan:")
    print(f"  Dense: {'ON' if plan['dense_vector'] else 'OFF'} (weight={plan['weights']['dense']})")
    print(f"  Sparse: {'ON' if plan['sparse_keyword'] else 'OFF'} (weight={plan['weights']['sparse']})")
    print(f"  Graph: hops={plan['graph_max_hops']}")
    print(f"  Abstractions: {plan['target_abstractions']}")
    print(f"  Budget: {plan['max_token_budget']} tokens")
    if plan["force_exact_matches"]:
        print(f"  Exact matches: {plan['force_exact_matches']}")

    if args.live:
        from src.pipeline import KnowledgePipeline
        config = load_config(args.workspace)
        pipeline = KnowledgePipeline(config)
        print("\nExecuting retrieval...")
        try:
            context = pipeline.query(args.query, model=args.model, verbose=args.verbose)
            print(f"\n--- Context ({len(context)} chars) ---\n")
            print(context)
        except Exception as e:
            print(f"\nRetrieval failed: {e}")
            print("Are databases running? Try: ./scripts/db_setup.sh")

    if args.json:
        print(json.dumps(metadata, indent=2))


def cmd_mcp(args):
    """Start the MCP server for AI CLI integration."""
    from src.mcp_server import main as mcp_main
    mcp_main()


def cmd_install(args):
    """Show installation instructions for global access."""
    project_root = Path(__file__).resolve().parent

    if sys.platform == "win32":
        script = project_root / "scripts" / "install.ps1"
        print("Run in PowerShell:")
        print(f'  powershell -ExecutionPolicy Bypass -File "{script}"')
    else:
        script = project_root / "scripts" / "install.sh"
        print("Run in terminal:")
        print(f"  bash {script}")

    print()
    print("This will:")
    print("  1. Create ~/.k-os/config.yaml (global config)")
    print("  2. Install 'k-os' command globally")
    print("  3. Add /k-os slash command to Claude Code")

    if args.mcp:
        print()
        print("MCP server config for your AI CLI settings:")
        mcp_config = {
            "mcpServers": {
                "knowledge-os": {
                    "command": str(project_root / ".venv" / "bin" / "python"),
                    "args": [str(project_root / "src" / "mcp_server.py")]
                }
            }
        }
        if sys.platform == "win32":
            mcp_config["mcpServers"]["knowledge-os"]["command"] = str(
                project_root / ".venv" / "Scripts" / "python.exe"
            )
        print(json.dumps(mcp_config, indent=2))


def main():
    parser = argparse.ArgumentParser(
        prog="k-os",
        description="Knowledge OS — local knowledge compilation engine"
    )
    parser.add_argument("-w", "--workspace", default=None, help="Path to workspace/vault to scan (default: project root)")
    subparsers = parser.add_subparsers(dest="command")

    # scan
    scan_p = subparsers.add_parser("scan", help="Scan workspace for changes")
    scan_p.add_argument("-v", "--verbose", action="store_true")
    scan_p.add_argument("--json", action="store_true", help="Output JSON results")

    # parse
    parse_p = subparsers.add_parser("parse", help="Parse a single file")
    parse_p.add_argument("file", help="Path to file to parse")

    # compile
    compile_p = subparsers.add_parser("compile", help="Compile files into Knowledge Objects")
    compile_p.add_argument("-v", "--verbose", action="store_true")
    compile_p.add_argument("--json", action="store_true", help="Output objects as JSON")

    # index
    index_p = subparsers.add_parser("index", help="Compile and index into databases")
    index_p.add_argument("-v", "--verbose", action="store_true")

    # rebuild
    rebuild_p = subparsers.add_parser("rebuild", help="Full rebuild from scratch")
    rebuild_p.add_argument("-v", "--verbose", action="store_true")

    # status
    subparsers.add_parser("status", help="Show state database summary")

    # query
    query_p = subparsers.add_parser("query", help="Plan and execute a knowledge query")
    query_p.add_argument("query", help="Natural language query")
    query_p.add_argument("-m", "--model", default="auto", help="Output adapter (auto/claude/gpt/codex/qwen/gemini). Default: auto-detect from AI CLI")
    query_p.add_argument("--json", action="store_true", help="Output full plan as JSON")
    query_p.add_argument("--live", action="store_true", help="Execute retrieval against databases")
    query_p.add_argument("-v", "--verbose", action="store_true")

    # mcp
    subparsers.add_parser("mcp", help="Start MCP server for AI CLI integration")

    # install
    install_p = subparsers.add_parser("install", help="Show global installation instructions")
    install_p.add_argument("--mcp", action="store_true", help="Also show MCP server config")

    args = parser.parse_args()
    commands = {
        "scan": cmd_scan,
        "parse": cmd_parse,
        "compile": cmd_compile,
        "index": cmd_index,
        "rebuild": cmd_rebuild,
        "status": cmd_status,
        "query": cmd_query,
        "mcp": cmd_mcp,
        "install": cmd_install,
    }

    handler = commands.get(args.command)
    if handler:
        handler(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
